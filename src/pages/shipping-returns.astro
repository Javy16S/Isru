---
import Layout from '../layouts/Layout.astro';
import { storeInfo } from '../data/info';

const BASE = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL.slice(0, -1) : import.meta.env.BASE_URL;
---

<Layout title="Envíos y Devoluciones | Isru Studio">
  <main class="w-full max-w-4xl mx-auto px-4 md:px-12 pt-32 pb-20 animate-fade-in">
    <nav class="flex items-center gap-2 text-xs uppercase tracking-[0.2em] text-gray-500 mb-12">
        <a href={`${BASE}/`} class="hover:text-black transition-colors" data-i18n="nav.products">Home</a>
        <span>/</span>
        <span class="text-gray-900" data-i18n="pdp.shipping">Shipping & Returns</span>
    </nav>

    <h1 class="font-cinzel text-4xl text-gray-900 mb-8" data-i18n="pdp.shipping">Envíos y Devoluciones</h1>
    
    <div class="prose prose-gray max-w-none text-gray-600 font-light space-y-16 leading-relaxed">
      
      <!-- Shipping Section -->
      <section class="space-y-6">
        <h2 class="text-gray-900 font-normal uppercase tracking-widest text-xs border-b border-gray-100 pb-2">1. Logística de Envío</h2>
        <p class="text-sm">
          Todos los pedidos se procesan y envían desde nuestro taller en España. Recibirás un número de seguimiento en cuanto el paquete salga de nuestras manos.
        </p>
        
        <div class="overflow-x-auto pt-4">
            <table class="w-full text-left text-[10px] uppercase tracking-widest text-gray-500 border-collapse">
                <thead>
                    <tr class="border-b border-gray-100">
                        <th class="py-4 font-bold text-gray-900">Región</th>
                        <th class="py-4 font-bold text-gray-900 text-right">Plazo Estimado</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50 text-gray-400">
                    <tr>
                        <td class="py-4">España Peninsular</td>
                        <td class="py-4 text-right">24 - 48 Horas</td>
                    </tr>
                    <tr>
                        <td class="py-4">Baleares y Canarias</td>
                        <td class="py-4 text-right">3 - 5 Días Hábiles</td>
                    </tr>
                    <tr>
                        <td class="py-4">Unión Europea</td>
                        <td class="py-4 text-right">3 - 7 Días Hábiles</td>
                    </tr>
                    <tr>
                        <td class="py-4">Resto del Mundo</td>
                        <td class="py-4 text-right">7 - 15 Días Hábiles</td>
                    </tr>
                </tbody>
            </table>
        </div>
      </section>

      <!-- Returns Section -->
      <section class="space-y-6">
        <h2 class="text-gray-900 font-normal uppercase tracking-widest text-xs border-b border-gray-100 pb-2">2. Cómo Devolver</h2>
        <p class="text-sm">
            Si no estás 100% satisfecho con tu accesorio Isru, tienes 14 días naturales para solicitar una devolución.
        </p>
        
        <div class="grid md:grid-cols-3 gap-8 pt-4">
            <div class="space-y-2">
                <span class="block text-gray-900 font-bold text-[10px]">Paso 01</span>
                <p class="text-[10px] leading-relaxed">Contacta con nosotros enviando un email a info@isrustudio.com indicando tu número de pedido.</p>
            </div>
            <div class="space-y-2">
                <span class="block text-gray-900 font-bold text-[10px]">Paso 02</span>
                <p class="text-[10px] leading-relaxed">Prepara el paquete con el producto en su estado original y envuélvelo con cuidado.</p>
            </div>
            <div class="space-y-2">
                <span class="block text-gray-900 font-bold text-[10px]">Paso 03</span>
                <p class="text-[10px] leading-relaxed">Una vez recibamos el artículo en nuestro atelier, emitiremos el reembolso total de tu compra.</p>
            </div>
        </div>
      </section>

      <div class="pt-8 border-t border-gray-100">
        <p class="text-[10px] text-gray-400 uppercase tracking-widest">
            ¿Tienes más preguntas? <a href={`${BASE}/#contacto`} class="text-gray-900 underline underline-offset-4">Contáctanos</a>
        </p>
      </div>

    </div>
  </main>
</Layout>

<script define:vars={{ storeInfo }}>
  document.addEventListener('localeChanged', (e) => {
    const locale = e.detail.locale;
    const shippingText = document.getElementById('shipping-main-text');
    const returnsText = document.getElementById('returns-main-text');
    
    if (shippingText && storeInfo.shipping.content[locale]) {
        shippingText.textContent = storeInfo.shipping.content[locale];
    }
    if (returnsText && storeInfo.returns.content[locale]) {
        returnsText.textContent = storeInfo.returns.content[locale];
    }
  });
</script>

<style>
  .animate-fade-in {
    opacity: 0;
    animation: fadeIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
