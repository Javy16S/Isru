---
import Layout from '../../layouts/Layout.astro';
import { products } from '../../data/products';

export async function getStaticPaths() {
  return products.map(product => ({
    params: { id: product.id.toString() },
    props: { product },
  }));
}

const { product } = Astro.props;
const { id, name, price, description, front, back, color, category } = product;

const BASE = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL.slice(0, -1) : import.meta.env.BASE_URL;
const frontImg = `${BASE}/images/${front}`;
const backImg = `${BASE}/images/${back}`;

// Map color codes to premium names
const colorNames = {
   'blue': 'Azul Noche',
   'gold': 'Camel Natural',
   'white': 'Blanco Nieve',
   'black': 'Negro Carbón'
};
const displayNameColor = colorNames[color] || color.toUpperCase();
---

<Layout title={`${name.es} | IR Studio`} description={description.es}>
  <main class="w-full bg-[#fdfdfd]"
        data-product-id={id}
        data-product-name={name.es}
        data-product-price={price}
        data-product-image={frontImg}
        data-product-full={JSON.stringify(product)}>
    
    <div class="w-full max-w-[1920px] mx-auto px-4 md:px-12 pt-32 pb-32">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-3 text-[10px] md:text-xs uppercase tracking-[0.3em] font-light text-gray-400 mb-16 animate-fade-in pl-2">
        <a href={`${BASE}/`} class="hover-link hover:text-gray-900 transition-colors" data-i18n="nav.products">Shop</a>
        <span class="text-gray-300">/</span>
        <span class="text-gray-900 font-medium" id="pdp-breadcrumb-name">{name.es}</span>
      </nav>

      <div class="flex flex-col lg:flex-row gap-16 lg:gap-24 relative items-start">
        
        <!-- Cascada masiva de Galería (Columna Izda) -->
        <div class="w-full lg:w-3/5 space-y-4 md:space-y-6 animate-fade-in" style="animation-delay: 0.1s;">
          <div class="w-full bg-[#f9f6f0]/50 aspect-[3/4] md:aspect-[4/5] flex items-center justify-center p-8 overflow-hidden rounded-sm">
             <img src={frontImg} alt={name.es} class="w-[85%] h-[85%] object-contain scale-100 hover:scale-[1.04] transition-transform duration-[2000ms] ease-out drop-shadow-sm" />
          </div>
          <div class="w-full bg-[#f9f6f0]/30 aspect-[4/5] flex items-center justify-center p-8 overflow-hidden rounded-sm">
             <img src={backImg} alt={`${name.es} - Trasera`} class="w-[80%] h-[80%] object-contain scale-100 hover:scale-[1.04] transition-transform duration-[2000ms] ease-out drop-shadow-sm" />
          </div>
          <div class="w-full bg-[#f9f6f0]/50 aspect-square flex items-center justify-center overflow-hidden rounded-sm">
             <img src={frontImg} alt={`${name.es} - Detalle`} class="w-[110%] h-[110%] object-cover object-center translate-y-8 scale-110 hover:scale-[1.15] transition-transform duration-[3000ms] ease-out" />
          </div>
        </div>

        <!-- Columna Fija de Detalles (Derecha Sticky) -->
        <div class="w-full lg:w-2/5 lg:sticky lg:top-32 h-fit space-y-12 animate-fade-in" style="animation-delay: 0.2s;">
          
          <div class="space-y-6">
            <span class="text-[10px] md:text-xs uppercase tracking-[0.4em] text-gray-400" data-i18n={`cat.${category}`}>{category}</span>
            <h1 id="pdp-title" class="font-cinzel text-5xl md:text-6xl text-gray-900 font-light leading-[1.1] tracking-wide">{name.es}</h1>
            <p class="font-cinzel text-3xl text-gray-900 font-light tracking-wider">${price}</p>
          </div>

          <p id="pdp-desc" class="text-gray-600 leading-[1.8] font-light text-base md:text-lg tracking-wide border-t border-gray-100/60 pt-8">
            {description.es}
          </p>

          <div class="space-y-10 pt-4">
             <!-- Anillo Activo Color UI -->
             <div class="space-y-5">
                <span id="pdp-color-label" class="text-[10px] uppercase tracking-[0.3em] font-light text-gray-500">Color: <span class="text-gray-900 font-medium ml-2">{displayNameColor}</span></span>
                <div class="flex gap-4 items-center">
                   <!-- Activo -->
                   <button class={`relative w-8 h-8 rounded-full border border-gray-100 cursor-pointer flex items-center justify-center group ${color === 'gold' ? 'bg-[#D4AF37]' : color === 'blue' ? 'bg-[#1e3a8a]' : 'bg-gray-900'}`}>
                     <span class="absolute inset-[-6px] rounded-full border border-[#5b2333] opacity-100 transition-opacity"></span>
                   </button>
                   <!-- Inactivos simular -->
                   {color !== 'black' && <button class="w-6 h-6 rounded-full border border-gray-200 bg-gray-900 opacity-20 hover:opacity-100 transition-opacity cursor-not-allowed hover-icon"></button>}
                   {color !== 'gold' && <button class="w-6 h-6 rounded-full border border-gray-200 bg-[#D4AF37] opacity-20 hover:opacity-100 transition-opacity cursor-not-allowed hover-icon"></button>}
                </div>
             </div>

             <!-- Caja de Compras y Suma -->
             <div class="flex flex-col sm:flex-row gap-4 pt-4">
                <div class="flex items-center justify-between sm:justify-center border border-gray-200 rounded-sm">
                   <button id="decreaseBtn" class="px-6 py-4 hover:bg-[#f9f6f0] text-gray-500 hover-icon transition-colors">-</button>
                   <span id="quantity" class="px-2 py-4 text-sm min-w-[3rem] text-center font-light">1</span>
                   <button id="increaseBtn" class="px-6 py-4 hover:bg-[#f9f6f0] text-gray-500 hover-icon transition-colors">+</button>
                </div>
                
                <button id="add-to-cart-btn" class="flex-1 bg-[#5b2333] text-white uppercase tracking-[0.2em] font-cinzel text-xs py-5 hover:bg-[#3d1621] shadow-xl shadow-[#5b2333]/10 transition-all duration-300 transform group" data-i18n="pdp.add">
                   <span class="border-b border-transparent group-hover:border-white/50 pb-1 transition-colors">Añadir al carrito</span>
                </button>
             </div>
          </div>

          <!-- Componentes de Detalles Acordeón Puros -->
          <div class="border-t border-gray-200 pt-8 mt-12 space-y-6">
             <details class="group cursor-pointer">
                <summary class="flex justify-between items-center text-xs uppercase tracking-[0.2em] text-gray-900 list-none hover:text-[#5b2333] transition-colors hover-icon origin-left">
                   <span data-i18n="pdp.materials">Materiales & Artesanía</span>
                   <span class="transform group-open:rotate-180 transition-transform duration-300 font-light">+</span>
                </summary>
                <p class="text-gray-500 text-sm font-light mt-6 leading-relaxed bg-[#f9f6f0]/40 p-6 border-l border-[#5b2333]" data-i18n="pdp.materials.text">
                   Confeccionado individualmente por artesanos. Utilice piel vegana de primera resistencia. Limpiar con paño suave. Su calidad asegura una longevidad única.
                </p>
             </details>
             
             <details class="group cursor-pointer pt-6 border-t border-gray-100">
                <summary class="flex justify-between items-center text-xs uppercase tracking-[0.2em] text-gray-900 list-none hover:text-[#5b2333] transition-colors hover-icon origin-left">
                   <span data-i18n="pdp.shipping">Privilegios & Envíos</span>
                   <span class="transform group-open:rotate-180 transition-transform duration-300 font-light">+</span>
                </summary>
                <p class="text-gray-500 text-sm font-light mt-6 leading-relaxed bg-[#f9f6f0]/40 p-6 border-l border-[#5b2333]" data-i18n="pdp.shipping.text">
                   Nuestros bolsos se envían en cajas *IR* de regalo para todo el mundo. Dispone de un plazo mínimo de 30 días para tramitar devoluciones manteniendo el precinto intacto.
                </p>
             </details>
          </div>

        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  import { addCartItem, toggleCart } from '../../stores/cart';

  const decreaseBtn = document.getElementById('decreaseBtn');
  const increaseBtn = document.getElementById('increaseBtn');
  const quantitySpan = document.getElementById('quantity');
  const addToCartBtn = document.getElementById('add-to-cart-btn');
  const productContainer = document.querySelector('[data-product-full]');

  function updatePDP(locale) {
     if (!productContainer) return;
     try {
        const product = JSON.parse(productContainer.getAttribute('data-product-full') || '{}');
        const titleEl = document.getElementById('pdp-title');
        const descEl = document.getElementById('pdp-desc');

        if (titleEl && product.name) titleEl.textContent = product.name[locale] || product.name.es;
        if (descEl && product.description) descEl.textContent = product.description[locale] || product.description.es;
        
        productContainer.setAttribute('data-product-name', product.name[locale] || product.name.es);
     } catch(e) { console.error('Error on translating PDP', e); }
  }

  document.addEventListener('localeChanged', (e: any) => updatePDP(e.detail.locale));
  updatePDP(localStorage.getItem('isru_locale') || 'es');

  if (decreaseBtn && increaseBtn && quantitySpan) {
    decreaseBtn.addEventListener('click', () => {
      let q = parseInt(quantitySpan.textContent || '1');
      if (q > 1) quantitySpan.textContent = (q - 1).toString();
    });
    increaseBtn.addEventListener('click', () => {
       let q = parseInt(quantitySpan.textContent || '1');
       quantitySpan.textContent = (q + 1).toString();
    });
  }

  if (addToCartBtn) {
     addToCartBtn.addEventListener('click', () => {
         if (productContainer) {
            const id = parseInt(productContainer.getAttribute('data-product-id') || '0');
            const name = productContainer.getAttribute('data-product-name') || '';
            const price = parseFloat(productContainer.getAttribute('data-product-price') || '0');
            const image = productContainer.getAttribute('data-product-image') || '';
            const quantity = parseInt(quantitySpan?.textContent || '1');

            if (id && name) {
                // Flash boton premium feedback
                const originalText = addToCartBtn.innerHTML;
                addToCartBtn.innerHTML = `<span class="opacity-70 flex items-center justify-center gap-2"><svg class="animate-spin h-3 w-3" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" fill="none" stroke-width="3"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"></path></svg> Cesta...</span>`;
                setTimeout(() => {
                   addToCartBtn.innerHTML = originalText;
                   addCartItem({ id, name, price, image }, quantity);
                   toggleCart(true); 
                }, 400);
            }
        }
     });
  }
</script>

<style>
  .animate-fade-in {
    opacity: 0;
    animation: fadeIn 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
