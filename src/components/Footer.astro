---
---
<footer class="bg-gray-50 border-t border-gray-200 pt-16 pb-8">
  <div class="w-full max-w-[1920px] mx-auto px-4 md:px-8">
    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="text-gray-500 text-sm">
        © <span id="year">{new Date().getFullYear()}</span> <span class="font-cinzel font-bold text-gray-700">IR</span> — <span data-i18n="footer.rights">Todos los derechos reservados</span>
      </div>
      <nav class="flex flex-wrap justify-center md:justify-end gap-x-8 gap-y-4">
        <a href={`${import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL.slice(0,-1) : import.meta.env.BASE_URL}/care-guide`} class="text-xs uppercase tracking-widest text-gray-400 hover:text-gray-900 transition-colors" data-i18n="footer.care">Guía de Cuidado</a>
        <a href={`${import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL.slice(0,-1) : import.meta.env.BASE_URL}/shipping-returns`} class="text-xs uppercase tracking-widest text-gray-400 hover:text-gray-900 transition-colors" data-i18n="footer.shipping">Envíos y Devoluciones</a>
        <a href={`${import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL.slice(0,-1) : import.meta.env.BASE_URL}/warranty`} class="text-xs uppercase tracking-widest text-gray-400 hover:text-gray-900 transition-colors" data-i18n="footer.warranty">Garantía</a>
        <a href={`${import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL.slice(0,-1) : import.meta.env.BASE_URL}/privacy`} class="text-xs uppercase tracking-widest text-gray-400 hover:text-gray-900 transition-colors" data-i18n="footer.privacy">Privacidad</a>
        <a href={`${import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL.slice(0,-1) : import.meta.env.BASE_URL}/terms`} class="text-xs uppercase tracking-widest text-gray-400 hover:text-gray-900 transition-colors" data-i18n="footer.terms">Términos</a>
      </nav>
      </nav>
    </div>
  </div>
</footer>
