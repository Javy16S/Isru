---
const BASE = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL.slice(0, -1) : import.meta.env.BASE_URL;
---

<header id="mainHeader" class="sticky top-0 z-[100] bg-white border-b border-gray-100 transition-all duration-500 h-24 flex items-center group/header">
  <div class="w-full max-w-[1920px] mx-auto px-4 md:px-12 flex items-center justify-between transition-all duration-500">
    <!-- Logo -->
    <a class="block w-24 md:w-28 opacity-95 hover:opacity-100 transition-opacity" href={`${BASE}/`}>
      <img src={`${BASE}/images/ISRU.svg`} alt="ISRU" class="w-full h-auto" />
    </a>
    
    <!-- Main Nav with Mega Menu -->
    <nav class="hidden md:flex gap-16 items-center h-full" id="mainNav">
      <!-- Mega Menu Trigger -->
      <div class="group/nav h-full flex items-center relative">
        <a class="text-[10px] uppercase tracking-[0.3em] font-bold text-gray-900 cursor-pointer py-11 hover:text-gray-400 transition-colors" href={`${BASE}/collections`} data-i18n="nav.products">Shop</a>
        
        <!-- The Mega Menu Dropdown -->
        <div class="absolute top-full left-0 w-[400px] bg-white border border-gray-100 shadow-2xl opacity-0 translate-y-4 pointer-events-none group-hover/nav:opacity-100 group-hover/nav:translate-y-0 group-hover/nav:pointer-events-auto transition-all duration-500 ease-out p-10 grid grid-cols-2 gap-10">
            <div class="space-y-6">
                <h4 class="text-[9px] uppercase tracking-widest text-gray-400 font-bold border-b border-gray-50 pb-2">Colecciones</h4>
                <ul class="space-y-4">
                    <li><a href={`${BASE}/collections`} class="text-[10px] uppercase tracking-widest text-gray-900 hover:text-gray-400 transition-colors">Ver Todo</a></li>
                    <li><a href={`${BASE}/collections/bolso`} class="text-[10px] uppercase tracking-widest text-gray-900 hover:text-gray-400 transition-colors">Bolsos</a></li>
                    <li><a href={`${BASE}/collections/cartera`} class="text-[10px] uppercase tracking-widest text-gray-900 hover:text-gray-400 transition-colors">Carteras</a></li>
                    <li><a href={`${BASE}/collections/organizador`} class="text-[10px] uppercase tracking-widest text-gray-900 hover:text-gray-400 transition-colors">Organizadores</a></li>
                </ul>
            </div>
            <div class="relative overflow-hidden group/img">
                <img src={`${BASE}/images/Bolso_Azul.webp`} alt="Isru Featured" class="w-full h-full object-cover transition-transform duration-700 group-hover/img:scale-105" />
                <div class="absolute inset-0 bg-black/5 flex items-end p-4">
                    <span class="text-[8px] uppercase tracking-widest text-white font-bold">New Arrival &bull; Blue Edition</span>
                </div>
            </div>
        </div>
      </div>

      <a class="text-[10px] uppercase tracking-[0.3em] font-bold text-gray-900 hover:text-gray-400 transition-colors" data-i18n="nav.about" href={`${BASE}/transparency`}>About</a>
      <a class="text-[10px] uppercase tracking-[0.3em] font-bold text-gray-900 hover:text-gray-400 transition-colors" data-i18n="nav.contact" href={`${BASE}/#contacto`}>Contact</a>
    </nav>

    <!-- Right Side (Cart, Lang, Menu) -->
    <div class="flex items-center gap-8">
      <!-- Language Switcher (Keep Existing Logic) -->
      <div class="hidden md:flex items-center gap-2 relative group/lang" id="lang-container">
        <button id="lang-trigger" class="flex items-center gap-1 text-[10px] uppercase tracking-widest text-gray-900 hover:text-gray-400 transition cursor-pointer px-2 py-1">
           <span id="lang-label">ES</span>
           <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"></path></svg>
        </button>
        <div id="lang-options" class="hidden absolute top-full right-0 mt-3 w-24 bg-white shadow-xl border border-gray-50 py-1 z-[110]">
           <button class="block w-full text-left px-4 py-2 text-[10px] uppercase tracking-widest text-gray-500 hover:bg-gray-50 hover:text-black" data-value="es">Español</button>
           <button class="block w-full text-left px-4 py-2 text-[10px] uppercase tracking-widest text-gray-500 hover:bg-gray-50 hover:text-black" data-value="en">English</button>
           <button class="block w-full text-left px-4 py-2 text-[10px] uppercase tracking-widest text-gray-500 hover:bg-gray-50 hover:text-black" data-value="fr">Français</button>
        </div>
        <select id="langSelect" class="hidden"><option value="es">ES</option><option value="en">EN</option><option value="fr">FR</option></select>
      </div>

      <!-- Cart Icon -->
      <button id="cart-trigger" class="text-gray-900 hover:text-gray-400 transition-colors relative" aria-label="Cart">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
        <span id="cart-count" class="absolute -top-1 -right-1 bg-gray-900 text-white text-[8px] w-3.5 h-3.5 flex items-center justify-center rounded-full opacity-0 transition-opacity">0</span>
      </button>

      <!-- Mobile Toggle -->
      <button class="md:hidden text-gray-900 focus:outline-none" id="navToggle" aria-label="Menu">
         <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 6h16M4 12h16m-12 6h12"></path></svg>
      </button>
    </div>
  </div>

  <script>
    import { toggleCart, cartItems } from '../stores/cart';

    function initHeader() {
        const trigger = document.getElementById('lang-trigger');
        const options = document.getElementById('lang-options');
        const select = document.getElementById('langSelect') as HTMLSelectElement | null;
        const label = document.getElementById('lang-label');
        const mainHeader = document.getElementById('mainHeader');
        
        // Language Logic
        const saved = localStorage.getItem('isru_locale') || 'es';
        if (label) label.textContent = saved.toUpperCase();
        if (select) select.value = saved;

        trigger?.addEventListener('click', (e) => { e.stopPropagation(); options?.classList.toggle('hidden'); });
        options?.querySelectorAll('button').forEach(btn => {
            btn.addEventListener('click', () => {
                const val = btn.dataset.value;
                if (val && label && select) {
                    label.textContent = val.toUpperCase(); options?.classList.add('hidden');
                    select.value = val; select.dispatchEvent(new Event('change', { bubbles: true }));
                }
            });
        });
        document.addEventListener('click', (e) => { if (!trigger?.contains(e.target as Node)) options?.classList.add('hidden'); });

        // Cart Logic
        document.getElementById('cart-trigger')?.addEventListener('click', () => toggleCart(true));
        cartItems.subscribe(items => {
            const count = Object.values(items).reduce((acc, item) => acc + item.quantity, 0);
            const cartCount = document.getElementById('cart-count');
            if (cartCount) { cartCount.textContent = count.toString(); cartCount.classList.toggle('opacity-0', count === 0); }
        });

        // Scroll Effect
        window.addEventListener('scroll', () => {
            if (window.scrollY > 50) { mainHeader?.classList.add('h-20', 'shadow-sm'); mainHeader?.classList.remove('h-24'); } 
            else { mainHeader?.classList.remove('h-20', 'shadow-sm'); mainHeader?.classList.add('h-24'); }
        }, { passive: true });
    }

    document.addEventListener('DOMContentLoaded', initHeader);
    document.addEventListener('astro:after-swap', initHeader);
  </script>
</header>
