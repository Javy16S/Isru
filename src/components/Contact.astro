---
---
<section id="contacto" class="py-24 bg-[#f9f6f0]">
  <div class="w-full max-w-[1920px] mx-auto px-4 md:px-8 flex justify-center">
    <div class="w-full max-w-2xl relative">
      <h2 class="font-cinzel text-3xl font-light text-gray-900 mb-10 text-center tracking-wide" data-i18n="contact.title">Contacto</h2>
      
      <!-- Formulario -->
      <form id="contact-form" class="space-y-6 bg-white p-8 md:p-12 rounded-sm shadow-2xl shadow-gray-200/50 border border-gray-100 transition-all duration-500">
        <div>
          <label for="name" class="block text-xs uppercase tracking-widest text-gray-500 mb-2" data-i18n="contact.name">Nombre</label>
          <input id="name" name="name" type="text" placeholder="Tu nombre" required 
                 class="w-full px-4 py-4 rounded-sm bg-gray-50/50 border border-gray-200 focus:border-[#5b2333] outline-none focus:bg-white focus:ring-0 transition duration-300 font-light">
        </div>

        <div>
          <label for="email" class="block text-xs uppercase tracking-widest text-gray-500 mb-2" data-i18n="contact.email">Email</label>
          <input id="email" name="email" type="email" placeholder="tu@email.com" required
                 class="w-full px-4 py-4 rounded-sm bg-gray-50/50 border border-gray-200 focus:border-[#5b2333] outline-none focus:bg-white focus:ring-0 transition duration-300 font-light">
        </div>

        <div>
          <label for="mensaje" class="block text-xs uppercase tracking-widest text-gray-500 mb-2" data-i18n="contact.message">Mensaje</label>
          <textarea id="mensaje" name="mensaje" rows="4" placeholder="¿En qué podemos ayudarte?" required
                    class="w-full px-4 py-4 rounded-sm bg-gray-50/50 border border-gray-200 focus:border-[#5b2333] outline-none focus:bg-white focus:ring-0 transition duration-300 font-light resize-none"></textarea>
        </div>

        <button id="submit-btn" class="w-full bg-[#5b2333] text-white font-cinzel tracking-[0.2em] uppercase py-5 rounded-sm shadow-lg hover:bg-[#3d1621] hover:shadow-xl hover:shadow-[#5b2333]/20 transition-all duration-300 transform" 
                type="submit">
          <span id="btn-text" data-i18n="contact.send">Enviar Mensaje</span>
          <svg id="btn-loader" class="animate-spin hidden w-5 h-5 mx-auto text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"></path></svg>
        </button>
      </form>

      <!-- Mensaje de Éxito Oculto -->
      <div id="success-msg" class="absolute inset-0 flex flex-col items-center justify-center bg-white p-8 md:p-12 rounded-sm shadow-2xl shadow-gray-200/50 border border-gray-100 opacity-0 pointer-events-none transition-all duration-[800ms] translate-y-8 ease-out">
        <svg class="w-16 h-16 text-[#5b2333] mb-6 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="0.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        <h3 class="font-cinzel text-3xl text-gray-900 mb-4 font-light">Gracias</h3>
        <p class="text-gray-500 text-center font-light leading-relaxed">Hemos recibido tu mensaje.<br/>El equipo artesanal de IR se pondrá en contacto contigo pronto.</p>
      </div>
    
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const btnText = document.getElementById('btn-text');
    const btnLoader = document.getElementById('btn-loader');
    const successMsg = document.getElementById('success-msg');

    if(form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault(); // Evita recarga
        
        // Simular carga
        if(btnText && btnLoader) {
          btnText.classList.add('hidden');
          btnLoader.classList.remove('hidden');
        }
        
        // Simular envío a servidor
        setTimeout(() => {
          form.style.opacity = '0';
          form.style.pointerEvents = 'none';
          form.style.transform = 'scale(0.98)';
          
          if(successMsg) {
            successMsg.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-8');
            successMsg.classList.add('opacity-100', 'translate-y-0');
          }
        }, 1200);
      });
    }
  });
</script>
